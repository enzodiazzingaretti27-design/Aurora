# Plantilla de variables de entorno para el panel de reservas.
# Copiá este archivo como `.env.local` y completá los valores reales.
# En producción (Vercel), cargá estas mismas variables en el panel del proyecto.

# Usuario para iniciar sesión en /panel
ADMIN_USER=cecilia

# Contraseña del panel. Usá una clave larga y difícil de adivinar.
ADMIN_PASSWORD=

# Secreto para firmar la cookie de sesión. Generalo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=
